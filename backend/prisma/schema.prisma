// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())

  profile       Profile?
  interviews    Interview[]
  aptitudeTests AptitudeTest[]
}

model Profile {
  id              String @id @default(cuid())
  userId          String @unique
  skills          String
  experienceLevel String
  targetRole      String

  user User @relation(fields: [userId], references: [id])
}

model Interview {
  id            String    @id @default(cuid())
  userId        String
  company       String
  type          String
  difficulty    String
  questionCount Int       @default(0)
  followUpCount Int       @default(0)
  feedback      Feedback?
  isCompleted   Boolean   @default(false)
  createdAt     DateTime  @default(now())

  user User @relation(fields: [userId], references: [id])

  messages Message[]
}

model Message {
  id          String   @id @default(cuid())
  interviewId String
  sender      String
  message     String
  createdAt   DateTime @default(now())

  interview Interview @relation(fields: [interviewId], references: [id])
}

model Feedback {
  id String @id @default(cuid())

  interviewId String @unique

  technicalScore      Int
  communicationScore  Int
  problemSolvingScore Int

  strengths   String
  weaknesses  String
  suggestions String
  summary     String

  createdAt DateTime @default(now())

  interview Interview @relation(fields: [interviewId], references: [id])
}

model AptitudeTest {
  id String @id @default(cuid())

  userId     String
  company    String
  difficulty String

  score       Int?
  totalMarks  Int?
  isCompleted Boolean @default(false)

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  questions AptitudeQuestion[]
}

model AptitudeQuestion {
  id String @id @default(cuid())

  aptitudeTestId String

  question      String
  options       Json
  correctAnswer String
  explanation   String

  userAnswer String?

  aptitudeTest AptitudeTest @relation(fields: [aptitudeTestId], references: [id])
}
